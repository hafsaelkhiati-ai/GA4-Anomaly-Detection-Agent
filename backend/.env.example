# ════════════════════════════════════════════════════════════════
# GA4 Anomaly Detection Agent — .env.example
# ════════════════════════════════════════════════════════════════
# SAFE TO COMMIT TO GITHUB — contains only placeholders
# ────────────────────────────────────────────────────────────────
# HOW TO USE:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in your real values in .env
#   3. Never commit .env  (blocked by .gitignore)
# ════════════════════════════════════════════════════════════════

# ── Google Analytics 4 ──────────────────────────────────────────
# Found in: GA4 → Admin → Property Settings → Property ID
GA4_PROPERTY_ID=YOUR_GA4_PROPERTY_ID

# Path to service account JSON key (relative to backend/ folder)
# 1. Google Cloud Console → IAM → Service Accounts → Create
# 2. Grant "Viewer" role → Keys → Add Key → JSON → download
# 3. Save to: backend/secrets/ga4-service-account.json
# 4. GA4 Admin → Account Access Management → add service account email
GA4_CREDENTIALS_PATH=secrets/ga4-service-account.json

# ── OpenAI ──────────────────────────────────────────────────────
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ── Slack ───────────────────────────────────────────────────────
# 1. https://api.slack.com/apps → Create New App
# 2. OAuth & Permissions → Scopes: chat:write, chat:write.public
# 3. Install to Workspace → copy Bot User OAuth Token (xoxb-...)
# 4. In Slack: /invite @YourBotName  to the target channel
SLACK_BOT_TOKEN=xoxb-your-token-here
SLACK_CHANNEL=#ga4-alerts

# ── Email / SMTP ────────────────────────────────────────────────
# Gmail App Password (NOT your regular password):
# Google Account → Security → 2FA on → App Passwords → Mail → Generate
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=youremail@gmail.com
SMTP_PASSWORD=your-16-char-app-password

# Comma-separated alert recipients
ALERT_EMAILS=client@example.com,you@youragency.com

# ── Thresholds ──────────────────────────────────────────────────
ZSCORE_THRESHOLD=2.0
PCT_DEVIATION_THRESHOLD=20.0

# ── Scheduler ───────────────────────────────────────────────────
AGENT_RUN_TIME=07:00
