# ════════════════════════════════════════════════════════════════
# GA4 Anomaly Detection Agent — Environment Variables
# ════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in all values.
# NEVER commit .env to Git — it's already in .gitignore
# ════════════════════════════════════════════════════════════════

# ── Google Analytics 4 ──────────────────────────────────────────
# Your GA4 Property ID (numeric only, no "properties/" prefix)
# Found in: GA4 → Admin → Property Settings → Property ID
GA4_PROPERTY_ID=123456789

# Path to your service account JSON credentials file
# How to get it:
#   1. Google Cloud Console → IAM → Service Accounts → Create
#   2. Grant "Viewer" role
#   3. Keys → Add Key → JSON → download
#   4. Save to secrets/ folder (already gitignored)
GA4_CREDENTIALS_PATH=secrets/ga4-service-account.json

# ── OpenAI ──────────────────────────────────────────────────────
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ── Slack ───────────────────────────────────────────────────────
# Bot User OAuth Token (starts with xoxb-)
# How to get it:
#   1. https://api.slack.com/apps → Create New App → From Scratch
#   2. OAuth & Permissions → Bot Token Scopes: chat:write, chat:write.public
#   3. Install to Workspace → copy Bot User OAuth Token
#   4. In Slack: /invite @YourBotName to the channel
SLACK_BOT_TOKEN=xoxb-your-token-here
SLACK_CHANNEL=#ga4-alerts

# ── Email / SMTP ────────────────────────────────────────────────
# Gmail: Use an App Password (NOT your regular password)
# How to get Gmail App Password:
#   1. Enable 2FA on your Google Account
#   2. Google Account → Security → App Passwords
#   3. Select "Mail" → Generate → copy the 16-char password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=youremail@gmail.com
SMTP_PASSWORD=your-app-password-here

# Comma-separated list of recipient emails
ALERT_EMAILS=client@example.com,you@youragency.com

# ── Anomaly Detection Thresholds ────────────────────────────────
# Flag anomaly if |z-score| >= this value (default: 2.0)
ZSCORE_THRESHOLD=2.0

# Flag anomaly if |% change from 7-day avg| >= this value (default: 20.0)
PCT_DEVIATION_THRESHOLD=20.0
