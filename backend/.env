# ════════════════════════════════════════════════════════════════
# GA4 Anomaly Detection Agent — .env
# ════════════════════════════════════════════════════════════════
# NEVER COMMIT THIS FILE — it contains your real API keys
# This file is blocked by .gitignore
# ════════════════════════════════════════════════════════════════

# ── Google Analytics 4 ──────────────────────────────────────────
GA4_PROPERTY_ID=                        # e.g. 123456789
GA4_CREDENTIALS_PATH=secrets/ga4-service-account.json

# ── OpenAI ──────────────────────────────────────────────────────
OPENAI_API_KEY=                         # e.g. sk-abc123...

# ── Slack ───────────────────────────────────────────────────────
SLACK_BOT_TOKEN=                        # e.g. xoxb-1234567890-...
SLACK_CHANNEL=#ga4-alerts

# ── Email / SMTP ────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=                              # e.g. youremail@gmail.com
SMTP_PASSWORD=                          # e.g. abcd efgh ijkl mnop

# Comma-separated alert recipients
ALERT_EMAILS=                           # e.g. client@example.com,you@agency.com

# ── Thresholds ──────────────────────────────────────────────────
ZSCORE_THRESHOLD=2.0
PCT_DEVIATION_THRESHOLD=20.0

# ── Scheduler ───────────────────────────────────────────────────
AGENT_RUN_TIME=07:00
